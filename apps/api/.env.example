# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mentor_dashboard

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:21389/auth/google/callback
FRONTEND_URL=http://localhost:3000
ALLOWED_GOOGLE_EMAILS=mentor@example.com
ALLOWED_GOOGLE_DOMAINS=

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# App Session / Token Storage
APP_SESSION_SECRET=replace-with-at-least-32-random-characters
GOOGLE_TOKEN_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
AUTH_USERNAME=admin
AUTH_PASSWORD=your-password

# Server
PORT=21389
