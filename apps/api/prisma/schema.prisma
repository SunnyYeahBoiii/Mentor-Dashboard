generator client {
  provider     = "prisma-client"
  output       = "../generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id            String           @id @default(cuid())
  firstName     String
  middleName    String
  lastName      String
  birthyear     Int?
  school        String?
  province      String?
  paid_sections Int              @default(0)
  amount_paid   Int              @default(0)
  classes       StudentInClass[]
}

model Class {
  id              String           @id @default(cuid())
  name            String
  section_fee     Int?
  section_count   Int              @default(0)
  students_count  Int              @default(0)
  students        StudentInClass[]
  sections        Section[]
  runningSections RunningSection[]
}

model Section {
  id        String    @id @default(cuid())
  name      String
  class     Class     @relation(fields: [classId], references: [id])
  startTime DateTime?
  endTime   DateTime?
  classId   String
  className String
}

model RunningSection {
  id          String    @id @default(cuid())
  name        String
  class       Class     @relation(fields: [classId], references: [id])
  startTime   DateTime?
  classId     String
  className   String
  meetingLink String?
}

model StudentInClass {
  student   Student @relation(fields: [studentId], references: [id])
  studentId String
  class     Class   @relation(fields: [classId], references: [id])
  classId   String

  @@id([studentId, classId])
  @@map("Student_in_Class")
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  fullName           String
  avatar             String?
  googleRefreshToken String?   @map("refreshToken")
  sessionTokenHash   String?   @unique
  sessionExpiresAt   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}
